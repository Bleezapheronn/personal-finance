{
  "name": "personal-finance-local-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Prototype-only local API skeleton for personal-finance.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "import:backup": "tsx src/importBackup.ts",
    "compare:counts": "tsx src/compareBackupSqlite.ts",
    "compare:integrity": "tsx src/compareIntegrity.ts",
    "compare:financial": "tsx src/compareFinancialAggregates.ts",
    "compare:reports": "tsx src/compareReportTotals.ts",
    "compare:transactions": "tsx src/compareTransactionSamples.ts",
    "compare:budget-history": "tsx src/compareBudgetHistory.ts",
    "compare:budget-snapshot-generation": "tsx src/compareBudgetSnapshotGeneration.ts",
    "backup:sqlite": "tsx src/backupSqlite.ts",
    "restore:sqlite-rehearsal": "tsx src/restoreSqliteRehearsal.ts",
    "test:sqlite-backup-restore": "tsx src/testSqliteBackupRestore.ts",
    "prepare:sqlite-authority-cutover": "tsx src/prepareSqliteAuthorityCutover.ts",
    "verify:sqlite-authority": "tsx src/verifySqliteAuthority.ts",
    "verify:sqlite-authority-rollback": "tsx src/verifySqliteAuthorityRollback.ts",
    "test:sqlite-authority-cutover": "tsx src/testSqliteAuthorityCutover.ts",
    "create:sqlite-authority-checkpoint": "tsx src/createSqliteAuthorityCheckpoint.ts",
    "verify:sqlite-authority-checkpoint": "tsx src/verifySqliteAuthorityCheckpoint.ts",
    "verify:sqlite-authority-checkpoint-chain": "tsx src/verifySqliteAuthorityCheckpointChain.ts",
    "test:sqlite-authority-checkpoint": "tsx src/testSqliteAuthorityCheckpoint.ts",
    "test:transaction-delete": "tsx src/testTransactionDelete.ts",
    "test:budget-lifecycle": "tsx src/testBudgetLifecycle.ts",
    "test:recipient-lifecycle": "tsx src/testRecipientLifecycle.ts",
    "test:account-lifecycle": "tsx src/testAccountLifecycle.ts",
    "test:category-lifecycle": "tsx src/testCategoryLifecycle.ts",
    "test:bucket-lifecycle": "tsx src/testBucketLifecycle.ts",
    "verify:sqlite": "tsx src/verifySqlitePrototype.ts",
    "smoke:api": "tsx src/smokeApi.ts",
    "token:show": "tsx src/tokenCli.ts show",
    "token:rotate": "tsx src/tokenCli.ts rotate"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
