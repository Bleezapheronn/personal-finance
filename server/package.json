{
  "name": "personal-finance-local-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Prototype-only local API skeleton for personal-finance.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "import:backup": "tsx src/importBackup.ts",
    "compare:counts": "tsx src/compareBackupSqlite.ts",
    "compare:integrity": "tsx src/compareIntegrity.ts",
    "compare:financial": "tsx src/compareFinancialAggregates.ts",
    "compare:reports": "tsx src/compareReportTotals.ts",
    "compare:transactions": "tsx src/compareTransactionSamples.ts",
    "token:show": "tsx src/tokenCli.ts show",
    "token:rotate": "tsx src/tokenCli.ts rotate"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
